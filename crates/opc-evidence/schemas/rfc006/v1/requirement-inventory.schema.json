{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.openpacketcore.dev/rfc006/v1/requirement-inventory.schema.json",
  "title": "OpenPacketCore RFC 006 requirement inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "requirements"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "source", "document", "release", "section"],
        "properties": {
          "id": {
            "type": "string",
            "format": "opc-requirement-id"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "document": {
            "type": "string",
            "minLength": 1
          },
          "release": {
            "type": "string",
            "minLength": 1
          },
          "section": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
