{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.openpacketcore.dev/rfc006/v1/gap-record.schema.json",
  "title": "OpenPacketCore RFC 006 known gap record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "status", "severity", "applies_to", "created"],
  "properties": {
    "id": {
      "type": "string",
      "format": "opc-gap-id"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "deferred"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "applies_to": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "opc-requirement-id"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "target_release": {
      "type": "string",
      "minLength": 1
    },
    "mitigation": {
      "type": "string",
      "minLength": 1
    },
    "security_impact": {
      "type": "string",
      "minLength": 1
    },
    "security_approval": {
      "type": "string",
      "minLength": 1
    },
    "performance_impact": {
      "type": "string",
      "minLength": 1
    }
  }
}
