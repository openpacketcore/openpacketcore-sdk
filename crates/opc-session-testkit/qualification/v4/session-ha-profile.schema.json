    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequential_schedule_schema",
        "sequential_history_schema",
        "sequential_checker",
        "concurrent_evidence_schema",
        "concurrent_history_schema",
        "concurrent_checker",
        "candidate_manifest_schema",
        "required_topologies",
        "required_transport_modes",
        "foundation_transport_mode",
        "foundation_counts_for_tls_rotation",
        "foundation_payload_protection",
        "foundation_counts_for_production_encryption",
        "unresolved_dependencies",
        "acceptance_gates"
      ],
      "properties": {
        "sequential_schedule_schema": {
          "const": "qualification/v1/session-ha-schedule.schema.json"
        },
        "sequential_history_schema": {
          "const": "qualification/v1/session-ha-history.schema.json"
        },
        "sequential_checker": { "const": "scripts/check-session-ha-history.py" },
        "concurrent_evidence_schema": {
          "const": "qualification/v3/session-ha-candidate-evidence.schema.json"
        },
        "concurrent_history_schema": {
          "const": "qualification/v3/session-ha-concurrent-history.schema.json"
        },
        "concurrent_checker": {
          "const": "scripts/check-session-ha-concurrent-history.py"
        },
        "candidate_manifest_schema": {
          "const": "qualification/v4/session-ha-candidate-manifest.schema.json"
        },
        "required_topologies": { "const": [3, 5] },
        "required_transport_modes": { "const": ["mtls"] },
        "foundation_transport_mode": { "const": "loopback-plaintext-test-only" },
        "foundation_counts_for_tls_rotation": { "const": false },
        "foundation_payload_protection": {
          "const": "fixed-memory-provider-synthetic-wrapper-only"
        },
        "foundation_counts_for_production_encryption": { "const": false },
        "unresolved_dependencies": { "const": [143, 158, 164] },
        "acceptance_gates": {
          "const": [
            "deployed_kubernetes_3_5",
            "real_network_and_storage_faults",
            "crash_point_matrix",
            "version_migration_and_rollback",
            "platform_resource_soak",
            "remote_hkms_rotation",
            "live_alert_fire_and_clear",
            "signed_release_bundle"
