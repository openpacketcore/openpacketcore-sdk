{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpacketcore.dev/schemas/session-ha-profile/v4-candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "maturity",
    "qualification_complete",
    "workspace",
    "source_build_gate",
    "artifacts",
    "platforms",
    "topology",
    "protocol",
    "consensus_timing",
    "bounds",
    "provisional_test_thresholds",
    "evidence"
  ],
  "properties": {
    "schema_version": { "const": "opc-session-ha-profile/v4-candidate" },
    "profile_id": { "const": "opc-session-openraft-ha/v4-candidate" },
    "maturity": { "const": "experimental" },
    "qualification_complete": { "const": false },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "rust_msrv", "source_revision"],
      "properties": {
        "version": { "const": "0.2.0" },
        "rust_msrv": { "const": "1.88" },
        "source_revision": { "const": "required-in-evidence" }
      }
    },
    "source_build_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracking_issue",
        "openraft_git",
        "openraft_rev",
        "affected_workspace_crates",
        "crates_io_check_date",
        "crates_io_exact_matches",
        "removal_condition"
      ],
      "properties": {
        "tracking_issue": { "const": 143 },
        "openraft_git": { "const": "https://github.com/openpacketcore/openraft" },
        "openraft_rev": { "const": "f607e636406b16bd0ad7925dbb631da1b7a4cd96" },
        "affected_workspace_crates": {
          "const": [
            "opc-alarm",
            "opc-alarm-k8s",
            "opc-alarm-testkit",
            "opc-alarm-yang",
            "opc-amf-lite",
            "opc-amf-lite-testkit",
            "opc-config-bus",
            "opc-consensus",
            "opc-gnmi-server",
            "opc-ipsec-lb",
            "opc-mgmt-authz",
            "opc-mgmt-transport",
            "opc-netconf-server",
            "opc-persist",
            "opc-runtime",
            "opc-sa-mirror",
            "opc-sbi",
            "opc-sdk",
            "opc-sdk-integration",
            "opc-session-cache",
            "opc-session-net",
            "opc-session-store",
            "opc-session-testkit",
            "operator-controller",
            "operator-lifecycle",
            "operator-lifecycle-cli"
          ]
        },
        "crates_io_check_date": { "const": "2026-07-13" },
        "crates_io_exact_matches": { "type": "array", "maxItems": 0 },
        "removal_condition": {
          "const": "official stable Openraft release containing the fix, registry pin and checksum, and full issue #143 requalification"
        }
      }
    },
    "artifacts": {
      "const": [
        {
          "crate_name": "opc-consensus",
          "version": "0.2.0",
          "publish": false,
          "required_features": [],
          "excluded_features": []
        },
        {
          "crate_name": "opc-session-store",
          "version": "0.2.0",
          "publish": false,
          "required_features": [],
          "excluded_features": []
        },
        {
          "crate_name": "opc-persist",
          "version": "0.2.0",
          "publish": false,
          "required_features": [],
          "excluded_features": []
        },
        {
          "crate_name": "opc-session-net",
          "version": "0.2.0",
          "publish": false,
          "required_features": [],
          "excluded_features": [
            "insecure-test",
            "legacy-session-net-compat"
          ]
        },
        {
          "crate_name": "openraft",
          "version": "0.9.24",
          "publish": false,
          "required_features": [
            "serde",
            "single-term-leader",
            "storage-v2"
          ],
          "excluded_features": []
        }
      ]
    },
    "platforms": {
      "const": [
        {
          "target": "x86_64-unknown-linux-gnu",
          "status": "qualification-pending"
        },
        {
          "target": "aarch64-unknown-linux-gnu",
          "status": "qualification-pending"
        }
      ]
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_counts",
        "maximum_members",
        "quorum_rule",
        "distinct_failure_domain_per_voter",
        "distinct_backing_store_per_voter",
        "stable_identity_independent_of_route"
