{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpacketcore.dev/schemas/session-ha-concurrent-history/v5",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "history_id",
    "history_operation_count",
    "operation_id",
    "process_id",
    "started_ns",
    "completed_ns",
    "operation"
  ],
  "properties": {
    "schema_version": { "const": "opc-session-ha-concurrent-history/v5" },
    "history_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "history_operation_count": { "type": "integer", "minimum": 1, "maximum": 10000 },
    "operation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "process_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "started_ns": { "type": "integer", "minimum": 0 },
    "completed_ns": { "type": "integer", "minimum": 0 },
    "operation": {
      "oneOf": [
        { "$ref": "#/$defs/batch" },
        { "$ref": "#/$defs/watch" },
        { "$ref": "#/$defs/restore" },
        { "$ref": "#/$defs/readiness" }
      ]
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "optionalGeneration": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "const": null }
      ]
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_sha256",
        "expected_generation",
        "new_generation",
        "owner_sha256",
        "fence",
        "state_class",
        "state_type_sha256",
        "expires_at_ns",
        "value_sha256"
      ],
      "properties": {
        "key_sha256": { "$ref": "#/$defs/digest" },
        "expected_generation": { "$ref": "#/$defs/optionalGeneration" },
        "new_generation": { "type": "integer", "minimum": 1 },
        "owner_sha256": { "$ref": "#/$defs/digest" },
        "fence": { "type": "integer", "minimum": 1 },
        "state_class": { "const": "authoritative-session" },
        "state_type_sha256": { "$ref": "#/$defs/digest" },
        "expires_at_ns": { "const": null },
        "value_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "batchSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot_index", "outcome", "journal_sequence", "mutation"],
      "properties": {
        "slot_index": { "type": "integer", "minimum": 1, "maximum": 16 },
        "outcome": {
          "enum": ["success", "conflict", "indeterminate", "unavailable"]
        },
        "journal_sequence": {
          "$comment": "Committed application-journal/watch sequence for a successful mutation; never an Openraft index.",
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "const": null }
          ]
        },
        "mutation": { "$ref": "#/$defs/mutation" }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "invocation_sequence", "outcome", "slots"],
      "properties": {
        "kind": { "const": "batch" },
        "invocation_sequence": { "type": "integer", "minimum": 1, "maximum": 64 },
        "outcome": { "enum": ["completed", "indeterminate", "unavailable"] },
        "slots": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/batchSlot" }
        }
      }
    },
    "watchEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journal_sequence",
        "batch_operation_id",
        "slot_index",
        "key_sha256",
        "generation",
        "owner_sha256",
        "fence",
        "state_class",
        "state_type_sha256",
        "expires_at_ns",
        "value_sha256"
      ],
      "properties": {
        "journal_sequence": {
          "$comment": "Committed application-journal/watch sequence; never an Openraft index.",
          "type": "integer",
          "minimum": 1
        },
        "batch_operation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "slot_index": { "type": "integer", "minimum": 1, "maximum": 16 },
        "key_sha256": { "$ref": "#/$defs/digest" },
        "generation": { "type": "integer", "minimum": 1 },
        "owner_sha256": { "$ref": "#/$defs/digest" },
        "fence": { "type": "integer", "minimum": 1 },
        "state_class": { "const": "authoritative-session" },
        "state_type_sha256": { "$ref": "#/$defs/digest" },
        "expires_at_ns": { "const": null },
        "value_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "watch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "outcome",
        "subscription_id",
        "requested_after_journal_sequence",
        "complete_through_journal_sequence",
        "events"
      ],
      "properties": {
        "kind": { "const": "watch" },
        "outcome": { "enum": ["success", "indeterminate", "unavailable"] },
        "subscription_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "requested_after_journal_sequence": { "type": "integer", "minimum": 0 },
        "complete_through_journal_sequence": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/watchEvent" }
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_sha256",
        "generation",
        "owner_sha256",
        "fence",
        "state_class",
        "state_type_sha256",
        "expires_at_ns",
        "value_sha256"
      ],
      "properties": {
        "key_sha256": { "$ref": "#/$defs/digest" },
        "generation": { "type": "integer", "minimum": 1 },
        "owner_sha256": { "$ref": "#/$defs/digest" },
        "fence": { "type": "integer", "minimum": 1 },
        "state_class": { "const": "authoritative-session" },
        "state_type_sha256": { "$ref": "#/$defs/digest" },
        "expires_at_ns": { "const": null },
        "value_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "restore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "outcome", "complete", "records"],
      "properties": {
        "kind": { "const": "restore" },
        "outcome": { "enum": ["success", "indeterminate", "unavailable"] },
        "complete": { "type": "boolean" },
        "records": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/record" }
        }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sample_sequence",
        "expected_quorum",
        "state",
        "raft_term",
        "raft_commit_index",
        "raft_applied_index",
        "journal_head"
      ],
      "properties": {
        "kind": { "const": "readiness" },
        "sample_sequence": { "type": "integer", "minimum": 1 },
        "expected_quorum": { "type": "boolean" },
        "state": { "enum": ["ready", "not_ready"] },
        "raft_term": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "const": null }
          ]
        },
        "raft_commit_index": {
          "$comment": "Exact Openraft commit index proven by a completed linearizable barrier; not an application-journal sequence.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        },
        "raft_applied_index": {
          "$comment": "Openraft applied index observed after the barrier; never compared numerically with journal_head.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        },
        "journal_head": {
          "$comment": "Linearizably observed committed application-journal/watch head; never an Openraft index.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        }
      }
    }
  }
}
