{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpacketcore.dev/schemas/session-ha-concurrent-history/v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "history_id",
    "history_operation_count",
    "operation_id",
    "process_id",
    "started_ns",
    "completed_ns",
    "operation"
  ],
  "properties": {
    "schema_version": { "const": "opc-session-ha-concurrent-history/v3" },
    "history_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "history_operation_count": { "type": "integer", "minimum": 1, "maximum": 10000 },
    "operation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "process_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "started_ns": { "type": "integer", "minimum": 0 },
    "completed_ns": { "type": "integer", "minimum": 0 },
    "operation": {
      "oneOf": [
        { "$ref": "#/$defs/batch" },
        { "$ref": "#/$defs/watch" },
        { "$ref": "#/$defs/restore" },
        { "$ref": "#/$defs/readiness" }
      ]
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "optionalGeneration": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "const": null }
      ]
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_sha256",
        "expected_generation",
        "new_generation",
        "owner_sha256",
        "fence",
        "value_sha256"
      ],
      "properties": {
        "key_sha256": { "$ref": "#/$defs/digest" },
        "expected_generation": { "$ref": "#/$defs/optionalGeneration" },
        "new_generation": { "type": "integer", "minimum": 1 },
        "owner_sha256": { "$ref": "#/$defs/digest" },
        "fence": { "type": "integer", "minimum": 1 },
        "value_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "outcome", "linearization_index", "mutations"],
      "properties": {
        "kind": { "const": "batch" },
        "outcome": {
          "enum": ["success", "conflict", "indeterminate", "unavailable"]
        },
        "linearization_index": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "const": null }
          ]
        },
        "mutations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/mutation" }
        }
      }
    },
    "watchEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit_index",
        "batch_operation_id",
        "mutation_offset",
        "key_sha256",
        "generation",
        "owner_sha256",
        "fence",
        "value_sha256"
      ],
      "properties": {
        "commit_index": { "type": "integer", "minimum": 1 },
        "batch_operation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "mutation_offset": { "type": "integer", "minimum": 1, "maximum": 16 },
        "key_sha256": { "$ref": "#/$defs/digest" },
        "generation": { "type": "integer", "minimum": 1 },
        "owner_sha256": { "$ref": "#/$defs/digest" },
        "fence": { "type": "integer", "minimum": 1 },
        "value_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "watch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "outcome",
        "subscription_id",
        "requested_after_index",
        "complete_through_index",
        "events"
      ],
      "properties": {
        "kind": { "const": "watch" },
        "outcome": { "enum": ["success", "indeterminate", "unavailable"] },
        "subscription_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "requested_after_index": { "type": "integer", "minimum": 0 },
        "complete_through_index": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/watchEvent" }
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_sha256", "generation", "owner_sha256", "fence", "value_sha256"],
      "properties": {
        "key_sha256": { "$ref": "#/$defs/digest" },
        "generation": { "type": "integer", "minimum": 1 },
        "owner_sha256": { "$ref": "#/$defs/digest" },
        "fence": { "type": "integer", "minimum": 1 },
        "value_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "restore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "outcome", "snapshot_index", "records"],
      "properties": {
        "kind": { "const": "restore" },
        "outcome": { "enum": ["success", "indeterminate", "unavailable"] },
        "snapshot_index": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        },
        "records": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/record" }
        }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sample_sequence",
        "expected_quorum",
        "state",
        "term",
        "commit_index",
        "applied_index"
      ],
      "properties": {
        "kind": { "const": "readiness" },
        "sample_sequence": { "type": "integer", "minimum": 1 },
        "expected_quorum": { "type": "boolean" },
        "state": { "enum": ["ready", "not_ready"] },
        "term": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "const": null }
          ]
        },
        "commit_index": {
          "$comment": "Exact commit index proven by the completed Openraft linearizable barrier.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        },
        "applied_index": {
          "$comment": "Applied index observed after barrier completion; it may be later than, but never earlier than, commit_index.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": null }
          ]
        }
      }
    }
  }
}
