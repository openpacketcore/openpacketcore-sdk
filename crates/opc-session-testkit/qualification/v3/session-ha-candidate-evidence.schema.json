{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpacketcore.dev/schemas/session-ha-candidate-evidence/v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "experimental",
    "qualification_complete",
    "counts_for_production",
    "source_revision",
    "source_tree_status",
    "artifact",
    "execution",
    "workload",
    "history",
    "checker",
    "coverage",
    "remaining_acceptance"
  ],
  "properties": {
    "schema_version": { "const": "opc-session-ha-candidate-evidence/v3" },
    "profile_id": { "const": "opc-session-openraft-ha/v3-candidate" },
    "experimental": { "const": true },
    "qualification_complete": { "const": false },
    "counts_for_production": { "const": false },
    "source_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "source_tree_status": { "enum": ["clean", "dirty_unqualified"] },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "sha256", "exact_release_artifact"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "sha256": { "$ref": "#/$defs/digest" },
        "exact_release_artifact": { "type": "boolean" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "history_id",
        "campaign_started_ns",
        "campaign_completed_ns",
        "topology_members",
        "process_ids",
        "max_readiness_gap_ns",
        "fault_schedule_sha256"
      ],
      "properties": {
        "history_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "campaign_started_ns": { "type": "integer", "minimum": 0 },
        "campaign_completed_ns": { "type": "integer", "minimum": 1 },
        "topology_members": { "oneOf": [{ "const": 3 }, { "const": 5 }] },
        "process_ids": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "max_readiness_gap_ns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60000000000
        },
        "fault_schedule_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schedule_sha256",
        "isolated_digest_namespace",
        "complete_write_history"
      ],
      "properties": {
        "schedule_sha256": { "$ref": "#/$defs/digest" },
        "isolated_digest_namespace": { "const": true },
        "complete_write_history": { "const": true }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "sha256", "operation_count", "required_kinds"],
      "properties": {
        "schema_version": { "const": "opc-session-ha-concurrent-history/v3" },
        "sha256": { "$ref": "#/$defs/digest" },
        "operation_count": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "required_kinds": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["batch", "watch", "restore", "readiness"] }
        }
      }
    },
    "checker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "sha256"],
      "properties": {
        "name": { "const": "check-session-ha-concurrent-history.py" },
        "version": { "const": "3" },
        "sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atomic_batch_serialization",
        "gap_free_watch",
        "exact_restore_snapshot",
        "continuous_readiness_gating"
      ],
      "properties": {
        "atomic_batch_serialization": { "const": true },
        "gap_free_watch": { "const": true },
        "exact_restore_snapshot": { "const": true },
        "continuous_readiness_gating": { "const": true }
      }
    },
    "remaining_acceptance": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "deployed_kubernetes_3_5",
          "real_network_and_storage_faults",
          "crash_point_matrix",
          "version_migration_and_rollback",
          "platform_resource_soak",
          "remote_hkms_rotation",
          "live_alert_fire_and_clear",
          "signed_release_bundle"
        ]
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
